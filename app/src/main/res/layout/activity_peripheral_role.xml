<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context="com.example.flasa.PeripheralRoleActivity"
    android:orientation="vertical"
    android:gravity="center_horizontal">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="?attr/actionBarSize"
        android:background="?attr/colorPrimary"/>


    <TextView
        android:id="@+id/mobil_cislo_1"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="50dp"
        android:textStyle="bold"
        android:gravity="center"
        android:text="DISARMED"
        android:textSize="42dp" />

    <!--
        <Button
            android:id="@+id/zavola_cislo1"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="VOLAJ" />
    -->

    <TextView
            android:id="@+id/xValue"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="48dp"
            android:text="TextView" />

    <TextView
        android:id="@+id/xValueZaciatocna"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="TextView" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="48dp"
        android:textSize="22dp"
        android:textStyle="bold"
        android:text="@string/gps_status" />

    <TextView
            android:id="@+id/txtViewLatGPS"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="TextView" />

        <TextView
            android:id="@+id/txtViewLonGPS"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="TextView" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="28dp"
        android:textStyle="bold"
        android:text="@string/battery_status"
        android:textSize="22dp" />

    <TextView
            android:id="@+id/txtBaterka"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="TextView" />


    </LinearLayout>
